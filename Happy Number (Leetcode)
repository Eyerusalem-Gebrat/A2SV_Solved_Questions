class Solution:
    def isHappy(self, n: int) -> bool:
        if n == 1: return True
        nums = set()
        _sum = 0
        while n != 1:
            while n > 0:
                _sum += (n % 10) ** 2
                n = n // 10
            n = _sum

            if n in nums:
                break
            nums.add(_sum)
            _sum = 0

        if n == 1: return True
        else: return False
