class Solution:
    def frequencySort(self, s: str) -> str:
        freq = {}
        res = []
        for i in  s:
            freq[i] = freq.get(i,0) + 1

        sortedFreq = dict(sorted(freq.items(), key=lambda item: item[1], reverse=True))

        for char, frequency in sortedFreq.items():
           res.extend(char * frequency)
        
        return "".join(res)
