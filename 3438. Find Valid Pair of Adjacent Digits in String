from collections import Counter
class Solution:
    def findValidPair(self, s: str) -> str:
        dic = Counter(s)
        for i in range(len(s) - 1):
            if s[i] != s[i+1]:
                if dic[s[i]] == int(s[i]) and dic[s[i+1]] == int(s[i+1]):
                    return s[i:i+2]
        return ""
